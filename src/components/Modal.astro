---
const { id = 'modal', title = '' } = Astro.props
---


<dialog
  id={id}
  class="modal fixed inset-0 z-50 flex items-center justify-center p-4"
  aria-labelledby={`${id}-title`}
>
  <form
    method="dialog"
    class="modal-panel relative w-full max-w-3xl rounded-2xl bg-slate-900 p-6 shadow-lg ring-1 ring-black/20 transition-transform"
  >
    <button
      type="button"
      class="modal-close-x absolute right-4 top-4 inline-flex h-9 w-9 items-center justify-center rounded-md text-white/90 hover:bg-white/10 focus:outline-none"
      aria-label="Cerrar"
    >
      <span aria-hidden="true">×</span>
    </button>

    <h3 id={`${id}-title`} class="text-lg font-semibold text-white">{title}</h3>

    <div class="mt-4 prose prose-invert max-w-none text-white">
      <slot />
    </div>
  </form>
</dialog>

<style>
  dialog[open] { padding: 0; border: none; }
  dialog:not([open]) { display: none; }
  dialog::backdrop { background: rgba(0,0,0,0.5); }
</style>

<script>
(function(){
  document.querySelectorAll('dialog.modal').forEach((dlg) => {
    const panel = dlg.querySelector('.modal-panel');
    const closeX = dlg.querySelector('.modal-close-x');
    closeX && closeX.addEventListener('click', (ev) => { ev.stopPropagation(); dlg.close(); });
    dlg.addEventListener('keydown', (e) => { if(e.key === 'Escape') dlg.close(); });
    dlg.addEventListener('click', (e) => { if(e.target === dlg) dlg.close(); });

    try {
      const origShow = dlg.showModal.bind(dlg);
      dlg.showModal = function(){
        // Save scroll position and active element so closing can restore them
        try {
          dlg.__scrollPos = { x: window.scrollX || window.pageXOffset, y: window.scrollY || window.pageYOffset };
          dlg.__prevActive = document.activeElement;
        } catch (e) {}
        origShow();
        dlg.__openedAt = Date.now();
      }
    } catch(err) {}

    // Restore scroll/focus when the dialog is closed
    dlg.addEventListener('close', () => {
      try {
        // Restore focus first
        if (dlg.__prevActive && typeof dlg.__prevActive.focus === 'function') {
          dlg.__prevActive.focus();
        }
        // Then restore scroll (use timeout to allow browser default focus scrolling to finish)
        if (dlg.__scrollPos) {
          setTimeout(() => {
            window.scrollTo(dlg.__scrollPos.x, dlg.__scrollPos.y);
          }, 0);
        }
      } catch (e) {}
    });

    document.addEventListener('click', (e) => {
      if(!dlg.open) return;
      if(dlg.__openedAt && (Date.now() - dlg.__openedAt) < 120) return;
      if(panel && !panel.contains(e.target)) dlg.close();
    }, true);
  });
})();
</script>
